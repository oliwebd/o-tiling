{
  "$schema": "https://json.schemastore.org/package",
  "name": "o-tiling",
  "version": "2.4.6",
  "description": "Window auto-tiling engine for GNOME Shell.",
  "author": "oliwebd",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "deploy": "pnpm run lint && pnpm run type-check && pnpm run build",
    "debug": "bash scripts/debug.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@girs/gjs": "4.0.0-rc.13",
    "@girs/gnome-shell": "^50.0.0",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}