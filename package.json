{
  "$schema": "https://json.schemastore.org/package",
  "name": "o-tiling",
  "version": "2.9.15",
  "description": "Auto-tiling extension for GNOME Shell with 'Aura' focus border, customizable workspace overview styling, and theme consistency.",
  "author": "oliwebd",
  "type": "module",
  "scripts": {
    "build": "tsc && prettier --write 'dist/**/*.js' && node scripts/format-dist.mjs",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "deploy": "pnpm run lint && pnpm run type-check && pnpm run build",
    "lint:dist": "../GER/ego-lint ./dist",
    "shexli": "make shexli",
    "log": "journalctl -f -o cat /usr/bin/gnome-shell | grep o-tiling",
    "local-install": "make install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@girs/gjs": "4.0.0-rc.13",
    "@girs/gnome-shell": "^50.0.0",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}