{
  "$schema": "https://json.schemastore.org/package",
  "name": "o-tiling",
  "version": "2.8.0",
  "description": "Auto-tiling extension for GNOME Shell with 'Aura' focus border, customizable workspace overview styling, and theme consistency.",
  "author": "oliwebd",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "deploy": "pnpm run lint && pnpm run type-check && pnpm run build",
    "debug": "bash scripts/debug.sh",
    "shexli": "make shexli"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@girs/gjs": "4.0.0-rc.13",
    "@girs/gnome-shell": "^50.0.0",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "pnpm@11.1.0+sha512.0c44e842e5686b2c061a81adda8b2258bd8818e9704b2cf2c63d56b931a7b2e910092e085027003b96ca3911ab56a07f6df5abaed2be9925034cdd686a535b14"
}
