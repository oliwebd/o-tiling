{
  "$schema": "https://json.schemastore.org/package",
  "name": "o-tiling",
  "version": "2.6.0",
  "description": "A high-performance auto-tiling engine for modern GNOME Shell featuring the 'Aura' focus border, customizable workspace overview styling, and session-wide theme consistency.",
  "author": "oliwebd",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "deploy": "pnpm run lint && pnpm run type-check && pnpm run build",
    "debug": "bash scripts/debug.sh",
    "shexli": "make shexli"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@girs/gjs": "4.0.0-rc.13",
    "@girs/gnome-shell": "^50.0.0",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
