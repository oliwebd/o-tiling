{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "sourceMap": false,
        "strict": true,
        "skipLibCheck": true,
        "target": "ES2022",
        "lib": ["ES2022"],
        "allowJs": true,
        "noEmit": true
    },
    "include": ["src/ambient.d.ts", "src/**/*.ts", "build.ts"],
    "exclude": ["node_modules"]
}