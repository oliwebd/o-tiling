{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "sourceMap": false,
        "strict": true,
        "skipLibCheck": true,
        "target": "ES2023",
        "lib": [
            "ES2023"
        ],
        "allowJs": true,
        "noEmit": true,
        "types": ["node"]
    },
    "include": [
        "src/ambient.d.ts",
        "src/stubs.d.ts",
        "src/**/*.ts",
        "build.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}